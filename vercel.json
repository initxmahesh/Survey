{
  "version": 2,
  "installCommand": "npm install --include=dev",
  "buildCommand": "npm run build --prefix client",
  "outputDirectory": "client/dist",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/[...path].ts": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
